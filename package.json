{
  "name": "ear-training-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter ear-training-station dev",
    "build": "pnpm --filter ear-training-station build",
    "sync:app": "pnpm --filter ear-training-station exec svelte-kit sync",
    "test": "pnpm run sync:app && vitest run",
    "test:watch": "pnpm run sync:app && vitest",
    "typecheck": "pnpm -r run typecheck",
    "test:e2e": "pnpm --filter ear-training-station test:e2e",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@vitest/ui": "4.1.5",
    "eslint": "10.2.0",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
