{
  "name": "ear-training-station",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && rm -rf build/harness",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "test:e2e": "svelte-kit sync && playwright test"
  },
  "dependencies": {
    "@ear-training/core": "workspace:*",
    "@ear-training/ui-tokens": "workspace:*",
    "@ear-training/web-platform": "workspace:*"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@ear-training/e2e-audio-testing": "workspace:*",
    "@playwright/test": "1.59.1",
    "@sveltejs/adapter-static": "^3",
    "@sveltejs/kit": "^2",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@testing-library/user-event": "14.6.1",
    "@vite-pwa/sveltekit": "1.1.0",
    "fake-indexeddb": "6.0.0",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "vite": "8.0.10",
    "workbox-window": "7.4.0"
  }
}
